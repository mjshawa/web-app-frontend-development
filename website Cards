#css

 body { 
  font-family: "Segoe UI", sans-serif; 
  background:#f2f6fb; 
  margin:0; 
}
main {
  max-width: 600px;
  margin: 60px auto;
  background:#fff;
  padding:32px;
  border-radius:8px;
}
h1 {
  color:#04AA6D;
  margin-top:0;
}
mark { 
  background:#fffd91;
}
button { 
  background:#04AA6D; 
  color:#fff; 
  border:none; 
  padding:12px 24px; 
  border-radius:999px; 
  cursor:pointer; 
}
button:hover { 
  background:#028a56; 
}


