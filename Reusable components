css

.card {
  overflow: hidden;
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 20px 40px rgba(15,23,42,0.12);
  display: grid;
  gap: 0;
}
.card img {
  width: 100%;
  height: auto;
}
.card-body {
  padding: 24px 28px;
}
.card-body h3 {
  margin-top: 0;
  margin-bottom: 12px;
}
.btn {
  display: inline-block;
  padding: 12px 20px;
  border-radius: 999px;
  font-weight: 600;
  text-decoration: none;
  transition: 0.2s ease;
  background: #04AA6D;
  color: #fff;
}
.btn:hover {
  background: #028a56;
}
